---
// AdSlot.astro — Placeholder estricto para Google AdSense
// CLS=0: dimensiones fijadas en CSS, no en el DOM dinámico
// Cuando AdSense esté activo, reemplazar el placeholder div con el script de ad
export interface Props {
  slot: 'leaderboard' | 'rectangle' | 'multiplex' | 'sidebar';
  class?: string;
}

const SLOT_DIMENSIONS: Record<Props['slot'], { w: number; h: number; label: string }> = {
  leaderboard: { w: 728, h: 90,  label: '728×90 — Leaderboard' },
  rectangle:   { w: 336, h: 280, label: '336×280 — Large Rectangle' },
  multiplex:   { w: 728, h: 280, label: '728×280 — Multiplex' },
  sidebar:     { w: 300, h: 600, label: '300×600 — Half Page' },
};

const { slot, class: className = '' } = Astro.props;
const dim = SLOT_DIMENSIONS[slot];
---

<div
  class:list={['ad-slot-wrapper', className]}
  style={`width:${dim.w}px; max-width:100%; aspect-ratio:${dim.w}/${dim.h};`}
  aria-hidden="true"
  data-ad-slot={slot}
>
  <div class="ad-slot-placeholder">
    <span class="ad-slot-label">{dim.label}</span>
  </div>
</div>

<style>
  .ad-slot-wrapper {
    /* Contenedor con aspect-ratio: evita CLS cuando el ad carga */
    display: block;
    overflow: hidden;
    background: transparent;
  }

  .ad-slot-placeholder {
    width: 100%;
    height: 100%;
    background: #f1f3f5;
    border: 1.5px dashed #ced4da;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ad-slot-label {
    font-family: monospace;
    font-size: 11px;
    color: #adb5bd;
    user-select: none;
    pointer-events: none;
  }

  /* En producción con AdSense activo: ocultar placeholder, mostrar ad */
  .ad-slot-wrapper.ad-loaded .ad-slot-placeholder {
    display: none;
  }
</style>
