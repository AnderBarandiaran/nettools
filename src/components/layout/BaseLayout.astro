---
import '../../styles/global.css';
import ThemeToggle from '../ThemeToggle';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const siteName = 'NetTools — Network Engineering Toolkit';
const fullTitle = title === siteName ? siteName : `${title} | NetTools`;
const ogImage = new URL('/og-default.png', Astro.url.origin).href;

const navLinks = [
  { href: '/subnetting/', label: 'Subnet Calc' },
  { href: '/subnetting/vlsm/', label: 'VLSM' },
  { href: '/cisco-scripts/', label: 'Cisco Scripts' },
  { href: '/topology/', label: 'Topology' },
  { href: '/articles/', label: 'Articles' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0F4C81" />

  <!-- Apply theme before paint — default is always light -->
  <script is:inline>
    (function(){var s=localStorage.getItem('nt-theme');if(s){document.documentElement.classList.toggle('dark',s==='dark');}else{document.documentElement.classList.remove('dark');}})();
  </script>

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2823740679718867" crossorigin="anonymous"></script>
</head>
<body>

  <!-- Nav -->
  <header style="background: var(--bg-1); border-bottom: 1px solid var(--border-1); position: sticky; top: 0; z-index: 40;">
    <div style="max-width: var(--maxw-content); margin: 0 auto; padding: 0 var(--gutter);">
      <nav
        style="
          display: flex;
          align-items: center;
          height: 56px;
          gap: var(--sp-8);
        "
        aria-label="Main navigation"
      >
        <!-- Logo -->
        <a
          href="/"
          style="
            font-family: var(--font-sans);
            font-weight: 700;
            font-size: 1rem;
            color: var(--fg-1);
            text-decoration: none;
            letter-spacing: var(--tr-tight);
            flex-shrink: 0;
          "
        >
          NetTools
        </a>

        <!-- Nav links -->
        <ul
          style="
            display: flex;
            align-items: center;
            gap: 0;
            margin: 0;
            padding: 0;
            list-style: none;
            overflow-x: auto;
            flex: 1;
            scrollbar-width: none;
          "
        >
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="nav-link"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <ThemeToggle client:load />
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <!-- Footer -->
  <footer style="border-top: 1px solid var(--border-1); margin-top: var(--sp-20); padding: var(--sp-12) 0; background: var(--bg-1);">
    <div style="max-width: var(--maxw-content); margin: 0 auto; padding: 0 var(--gutter);">
      <div style="display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: var(--sp-8);">

        <div>
          <p style="font-family: var(--font-sans); font-weight: 700; font-size: var(--t-body-s); color: var(--fg-1); letter-spacing: var(--tr-tight); margin-bottom: var(--sp-2);">
            NetTools
          </p>
          <p style="font-size: var(--t-caption); color: var(--fg-3); max-width: 30ch; line-height: var(--lh-body);">
            Free professional networking tools. No account. No data collection.
          </p>
        </div>

        <nav aria-label="Footer navigation">
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: var(--sp-1) var(--sp-6);">
            {[
              { href: '/subnetting/', label: 'Subnet Calculator' },
              { href: '/subnetting/vlsm/', label: 'VLSM Planner' },
              { href: '/cisco-scripts/', label: 'Cisco Scripts' },
              { href: '/topology/', label: 'Topology' },
              { href: '/articles/', label: 'Articles' },
              { href: '/about/', label: 'About' },
              { href: '/privacy/', label: 'Privacy' },
              { href: 'https://github.com/AnderBarandiaran/nettools', label: 'GitHub' },
            ].map(link => (
              <li>
                <a
                  href={link.href}
                  class="footer-link"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>

      </div>

      <div style="margin-top: var(--sp-8); padding-top: var(--sp-6); border-top: 1px solid var(--border-2); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-4);">
        <p style="font-size: var(--t-caption); color: var(--fg-3);">© {new Date().getFullYear()} NetTools</p>
        <p style="font-size: var(--t-caption); color: var(--fg-3);">Runs entirely in your browser.</p>
      </div>
    </div>
  </footer>

  <!-- IntersectionObserver: .fade-in → visible -->
  <script>
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));

    // Also handle legacy .scroll-entry class
    const io2 = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io2.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    document.querySelectorAll('.scroll-entry').forEach((el) => io2.observe(el));
  </script>

</body>
</html>

<style>
  .nav-link {
    display: block;
    padding: 0.375rem 0.625rem;
    font-family: var(--font-sans);
    font-size: var(--t-body-s);
    font-weight: 500;
    color: var(--fg-2);
    text-decoration: none;
    white-space: nowrap;
    border-radius: var(--r-2);
    transition: color var(--dur-quick) var(--ease-out);
  }
  .nav-link:hover {
    color: var(--fg-1);
  }

  .footer-link {
    font-size: var(--t-caption);
    color: var(--fg-3);
    text-decoration: none;
    transition: color var(--dur-quick) var(--ease-out);
  }
  .footer-link:hover {
    color: var(--fg-1);
  }
</style>
