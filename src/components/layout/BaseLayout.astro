---
import '../../styles/global.css';
import ThemeToggle from '../ThemeToggle';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const siteName = 'NetTools — Network Engineering Toolkit';
const fullTitle = title === siteName ? siteName : `${title} | NetTools`;
const ogImage = new URL('/og-default.png', Astro.url.origin).href;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#08080c" />

  <!-- FOUC prevention: default to dark, apply before paint -->
  <script is:inline>
    (function () {
      var saved = localStorage.getItem('nt-theme');
      var theme = saved || 'dark';
      document.documentElement.classList.toggle('dark', theme !== 'light');
    })();
  </script>

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- Floating pill nav -->
  <div class="sticky top-0 z-50 px-4 pt-3 pb-1 pointer-events-none">
    <div class="max-w-6xl mx-auto pointer-events-auto">
      <nav
        style="
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 0.5rem 0.875rem;
          gap: 1rem;
          background-color: rgba(8, 8, 12, 0.75);
          border: 1px solid rgba(255, 255, 255, 0.08);
          border-radius: 14px;
          backdrop-filter: blur(20px);
          -webkit-backdrop-filter: blur(20px);
          box-shadow: var(--shadow-nav);
          transition: background-color 250ms ease;
        "
        aria-label="Main navigation"
        class="nav-pill"
      >
        <!-- Logo -->
        <a
          href="/"
          style="
            font-family: 'Geist', 'Helvetica Neue', system-ui, sans-serif;
            font-weight: 700;
            font-size: 0.9375rem;
            color: var(--text-1);
            text-decoration: none;
            letter-spacing: -0.03em;
            flex-shrink: 0;
          "
        >
          NetTools
        </a>

        <!-- Nav links -->
        <ul
          style="
            display: flex;
            align-items: center;
            gap: 0.125rem;
            margin: 0;
            padding: 0;
            list-style: none;
            overflow-x: auto;
            flex: 1;
            scrollbar-width: none;
          "
        >
          {[
            { href: '/subnetting/', label: 'Subnet Calc' },
            { href: '/subnetting/vlsm/', label: 'VLSM' },
            { href: '/cisco-scripts/', label: 'Cisco Scripts' },
            { href: '/topology/', label: 'Topology' },
            { href: '/articles/', label: 'Articles' },
          ].map(link => (
            <li>
              <a
                href={link.href}
                style="
                  display: block;
                  padding: 0.375rem 0.6875rem;
                  border-radius: 8px;
                  font-family: 'Geist', 'Helvetica Neue', system-ui, sans-serif;
                  font-size: 0.8125rem;
                  font-weight: 500;
                  color: var(--text-3);
                  text-decoration: none;
                  white-space: nowrap;
                  letter-spacing: -0.01em;
                  transition: color 150ms ease, background-color 150ms ease;
                "
                onmouseover="this.style.color='var(--text-1)'; this.style.backgroundColor='rgba(255,255,255,0.06)'"
                onmouseout="this.style.color='var(--text-3)'; this.style.backgroundColor='transparent'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <ThemeToggle client:load />
      </nav>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer style="border-top: 1px solid var(--border-subtle); margin-top: 6rem; padding: 3rem 0;">
    <div class="max-w-6xl mx-auto px-4">
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div style="display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 2rem;">
          <div>
            <p style="font-family: 'Geist', sans-serif; font-weight: 700; font-size: 0.9375rem; color: var(--text-1); letter-spacing: -0.03em; margin-bottom: 0.5rem;">
              NetTools
            </p>
            <p style="font-size: 0.8125rem; color: var(--text-3); max-width: 28ch; line-height: 1.6;">
              Free professional tools for network engineers. No login required.
            </p>
          </div>
          <nav aria-label="Footer navigation" style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
            {[
              { href: '/subnetting/', label: 'Subnet Calculator' },
              { href: '/subnetting/vlsm/', label: 'VLSM Planner' },
              { href: '/cisco-scripts/', label: 'Cisco Scripts' },
              { href: '/topology/', label: 'Topology' },
              { href: '/articles/', label: 'Articles' },
              { href: '/about/', label: 'About' },
              { href: '/privacy/', label: 'Privacy' },
              { href: 'https://github.com/AnderBarandiaran/nettools', label: 'GitHub' },
            ].map(link => (
              <a
                href={link.href}
                style="
                  display: block;
                  padding: 0.3125rem 0.75rem;
                  border: 1px solid var(--border);
                  border-radius: 9999px;
                  font-size: 0.75rem;
                  color: var(--text-3);
                  text-decoration: none;
                  transition: color 150ms ease, border-color 150ms ease;
                "
                onmouseover="this.style.color='var(--text-1)'; this.style.borderColor='var(--border-hover)'"
                onmouseout="this.style.color='var(--text-3)'; this.style.borderColor='var(--border)'"
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>

        <div style="border-top: 1px solid var(--border-subtle); padding-top: 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
          <p style="font-size: 0.75rem; color: var(--text-3);">
            © {new Date().getFullYear()} NetTools. Built for network engineers.
          </p>
          <p style="font-size: 0.75rem; color: var(--text-3);">
            Zero data collection. Runs entirely in your browser.
          </p>
        </div>
      </div>
    </div>
  </footer>

  <!-- Scroll entry IntersectionObserver -->
  <script>
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.06, rootMargin: '0px 0px -30px 0px' }
    );
    document.querySelectorAll('.scroll-entry').forEach((el) => io.observe(el));
  </script>

  <!-- Light mode nav tweak -->
  <style>
    :root:not(.dark) .nav-pill {
      background-color: rgba(255, 255, 255, 0.85);
      border-color: rgba(0, 0, 0, 0.07);
    }
    :root:not(.dark) .nav-pill a[onmouseover] {
      color: var(--text-3);
    }
  </style>
</body>
</html>
