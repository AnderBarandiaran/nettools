---
import '../../styles/global.css';
import ThemeToggle from '../ThemeToggle';

export interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>;
  noindex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogType = 'website',
  jsonLd,
  noindex = false,
} = Astro.props;

const siteName = 'NetTools — Network Engineering Toolkit';
const fullTitle = title === siteName ? siteName : `${title} | NetTools`;
const ogImage = new URL('/og-default.png', Astro.url.origin).href;

const navLinks = [
  { href: '/subnetting/', label: 'Subnet Calc' },
  { href: '/subnetting/vlsm/', label: 'VLSM' },
  { href: '/cisco-scripts/', label: 'Cisco Scripts' },
  { href: '/topology/', label: 'Topology' },
  { href: '/articles/', label: 'Articles' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0066cc" />

  <!-- Apply theme before paint -->
  <script is:inline>
    (function () {
      var saved = localStorage.getItem('nt-theme');
      var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    })();
  </script>

  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:image" content={ogImage} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>

  <!-- Nav: flat, honest, no theatrics -->
  <header style="background-color: var(--surface); border-bottom: 1px solid var(--border);">
    <div class="max-w-6xl mx-auto px-4">
      <nav
        style="
          display: flex;
          align-items: center;
          height: 56px;
          gap: 2rem;
        "
        aria-label="Main navigation"
      >
        <a
          href="/"
          style="
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-1);
            text-decoration: none;
            letter-spacing: -0.02em;
            flex-shrink: 0;
          "
        >
          NetTools
        </a>

        <ul
          style="
            display: flex;
            align-items: center;
            gap: 0;
            margin: 0;
            padding: 0;
            list-style: none;
            overflow-x: auto;
            flex: 1;
            scrollbar-width: none;
          "
        >
          {navLinks.map(link => (
            <li>
              <a
                href={link.href}
                style="
                  display: block;
                  padding: 0.375rem 0.75rem;
                  font-family: 'DM Sans', sans-serif;
                  font-size: 0.875rem;
                  font-weight: 500;
                  color: var(--text-2);
                  text-decoration: none;
                  white-space: nowrap;
                  border-radius: 4px;
                  transition: color 120ms ease, background-color 120ms ease;
                "
                onmouseover="this.style.color='var(--text-1)'; this.style.backgroundColor='var(--canvas)'"
                onmouseout="this.style.color='var(--text-2)'; this.style.backgroundColor='transparent'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>

        <ThemeToggle client:load />
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer style="border-top: 1px solid var(--border); margin-top: 5rem; padding: 2.5rem 0; background-color: var(--surface);">
    <div class="max-w-6xl mx-auto px-4">
      <div style="display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: 2rem;">
        <div>
          <p style="font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 0.9375rem; color: var(--text-1); letter-spacing: -0.02em; margin-bottom: 0.375rem;">
            NetTools
          </p>
          <p style="font-size: 0.8125rem; color: var(--text-3); max-width: 30ch; line-height: 1.6;">
            Free professional networking tools. No account. No data collection.
          </p>
        </div>
        <nav aria-label="Footer navigation">
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.25rem 1.5rem;">
            {[
              { href: '/subnetting/', label: 'Subnet Calculator' },
              { href: '/subnetting/vlsm/', label: 'VLSM Planner' },
              { href: '/cisco-scripts/', label: 'Cisco Scripts' },
              { href: '/topology/', label: 'Topology' },
              { href: '/articles/', label: 'Articles' },
              { href: '/about/', label: 'About' },
              { href: '/privacy/', label: 'Privacy' },
              { href: 'https://github.com/AnderBarandiaran/nettools', label: 'GitHub' },
            ].map(link => (
              <li>
                <a
                  href={link.href}
                  style="
                    font-size: 0.8125rem;
                    color: var(--text-3);
                    text-decoration: none;
                    transition: color 120ms ease;
                  "
                  onmouseover="this.style.color='var(--text-1)'"
                  onmouseout="this.style.color='var(--text-3)'"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
      <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
        <p style="font-size: 0.75rem; color: var(--text-3);">© {new Date().getFullYear()} NetTools</p>
        <p style="font-size: 0.75rem; color: var(--text-3);">Runs entirely in your browser.</p>
      </div>
    </div>
  </footer>

  <!-- Scroll entry: opacity only -->
  <script>
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('in-view');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.05 }
    );
    document.querySelectorAll('.scroll-entry').forEach((el) => io.observe(el));
  </script>
</body>
</html>
