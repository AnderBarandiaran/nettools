---
import BaseLayout from '../components/layout/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "NetTools",
  "description": "Professional network engineering tools: subnet calculators, VLSM planners, Cisco script generators",
  "url": Astro.url.origin,
};

const tools = [
  {
    href: '/subnetting/',
    name: 'Subnet Calculator',
    description: 'Compute network address, broadcast, usable host range, and wildcard mask from any CIDR block.',
    badge: null,
  },
  {
    href: '/subnetting/vlsm/',
    name: 'VLSM Planner',
    description: 'Allocate subnets from a parent block using Variable Length Subnet Masking with utilization analysis.',
    badge: null,
  },
  {
    href: '/cisco-scripts/',
    name: 'Cisco IOS Scripts',
    description: 'Generate interface configurations, OSPF, static routes, and extended ACLs ready for console paste.',
    badge: null,
  },
  {
    href: '/topology/',
    name: 'Topology Simulator',
    description: 'Drag-and-drop network topology builder with automatic IP assignment and adjacency tables.',
    badge: 'Beta',
  },
];
---

<BaseLayout
  title="NetTools — Network Engineering Toolkit"
  description="Free professional tools for network engineers: subnet calculators, VLSM planners, Cisco IOS script generators, and topology simulators."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-14 pb-10">

    <p class="section-label" style="margin-bottom: 1rem;">
      Network engineering toolkit
    </p>

    <h1
      class="font-display scroll-entry"
      style="
        font-size: clamp(2.75rem, 5vw, 4.25rem);
        color: var(--text-1);
        max-width: 18ch;
        margin-bottom: 1.25rem;
      "
    >
      Network tools for engineers who know what they need
    </h1>

    <p
      class="scroll-entry"
      style="
        font-size: 1.0625rem;
        color: var(--text-2);
        max-width: 52ch;
        line-height: 1.65;
        margin-bottom: 2rem;
      "
    >
      Subnet calculators, VLSM planners, Cisco script generators, and topology
      tools. Free, no account required, runs entirely in your browser.
    </p>

    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 3.5rem;" class="scroll-entry">
      <a href="/subnetting/" class="btn-primary">Open Subnet Calculator</a>
      <a href="/articles/" class="btn-secondary">Read the guides</a>
    </div>
  </section>

  <!-- Stats strip: one horizontal line, pipe separators, no pills -->
  <div
    class="scroll-entry"
    style="
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      background-color: var(--surface);
    "
  >
    <div
      class="max-w-6xl mx-auto px-4"
      style="
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0;
        padding: 0.875rem 0;
      "
    >
      {[
        '127 unit tests passing',
        'Built with Astro',
        'Open source on GitHub',
        'Zero data collection',
      ].map((stat, i) => (
        <>
          {i > 0 && (
            <span aria-hidden="true" style="color: var(--border); padding: 0 1rem; font-size: 1rem; line-height: 1; flex-shrink: 0;">|</span>
          )}
          <span style="font-size: 0.8125rem; color: var(--text-3); font-weight: 500; white-space: nowrap;">{stat}</span>
        </>
      ))}
    </div>
  </div>

  <!-- Ad leaderboard -->
  <div style="display: flex; justify-content: center; padding: 2rem 1rem;">
    <AdSlot slot="leaderboard" />
  </div>

  <!-- Tool list: table style, no cards -->
  <section class="max-w-6xl mx-auto px-4 pb-20">

    <p class="section-label" style="margin-bottom: 0; padding-bottom: 0.875rem; border-bottom: 1px solid var(--border);">
      Tools
    </p>

    <ul role="list" style="list-style: none; padding: 0; margin: 0;">
      {tools.map(tool => (
        <li>
          <a
            href={tool.href}
            class="tool-row"
            aria-label={`Open ${tool.name}`}
          >
            <span class="tool-name">{tool.name}</span>
            <span class="tool-desc">{tool.description}</span>
            <span class="tool-meta">
              {tool.badge && (
                <span
                  style="
                    font-size: 0.6875rem;
                    font-weight: 700;
                    letter-spacing: 0.06em;
                    text-transform: uppercase;
                    color: var(--warning);
                    background-color: var(--warning-subtle);
                    padding: 0.2rem 0.5rem;
                    border-radius: 3px;
                    white-space: nowrap;
                  "
                >{tool.badge}</span>
              )}
              <span class="tool-arrow">→</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

<style>
  .tool-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    align-items: center;
    gap: 2rem;
    padding: 1.25rem 0.75rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    border-radius: 4px;
    transition: background-color 150ms ease;
    margin: 0 -0.75rem;
  }

  .tool-row:hover {
    background-color: var(--accent-subtle);
  }

  .tool-name {
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.9375rem;
    color: var(--text-1);
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .tool-desc {
    font-size: 0.875rem;
    color: var(--text-2);
    line-height: 1.55;
  }

  .tool-meta {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .tool-arrow {
    font-size: 1rem;
    color: var(--accent);
    display: inline-block;
    transition: transform 150ms ease;
  }

  .tool-row:hover .tool-arrow {
    transform: translateX(4px);
  }

  @media (max-width: 640px) {
    .tool-row {
      grid-template-columns: 1fr;
      gap: 0.375rem;
      padding: 1rem 0.5rem;
      margin: 0 -0.5rem;
    }
    .tool-meta {
      justify-content: flex-end;
    }
  }
</style>
