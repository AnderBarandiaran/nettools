---
import BaseLayout from '../components/layout/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "NetTools",
  "description": "Professional network engineering tools: subnet calculators, VLSM planners, Cisco script generators",
  "url": Astro.url.origin,
};

const tools = [
  {
    href: '/subnetting/',
    name: 'Subnet Calculator',
    description: 'Compute network address, broadcast, usable host range, and wildcard mask from any CIDR block.',
    badge: 'Free',
    badgeClass: 'badge-go',
  },
  {
    href: '/subnetting/vlsm/',
    name: 'VLSM Planner',
    description: 'Allocate subnets from a parent block using Variable Length Subnet Masking with utilization analysis.',
    badge: 'Free',
    badgeClass: 'badge-go',
  },
  {
    href: '/cisco-scripts/',
    name: 'Cisco IOS Scripts',
    description: 'Generate interface configurations, OSPF, static routes, and extended ACLs ready for console paste.',
    badge: 'Free',
    badgeClass: 'badge-go',
  },
  {
    href: '/topology/',
    name: 'Topology Simulator',
    description: 'Drag-and-drop network topology builder with automatic IP assignment and adjacency tables.',
    badge: 'Beta',
    badgeClass: 'badge-warn',
  },
];
---

<BaseLayout
  title="NetTools — Network Engineering Toolkit"
  description="Free professional tools for network engineers: subnet calculators, VLSM planners, Cisco IOS script generators, and topology simulators."
  jsonLd={jsonLd}
>

  <!-- Hero -->
  <section style="max-width: var(--maxw-content); margin: 0 auto; padding: var(--sp-20) var(--gutter) var(--sp-16);">

    <p class="eyebrow fade-in" style="margin-bottom: var(--sp-4);">
      Network engineering tools
    </p>

    <h1
      class="fade-in"
      style="
        font-family: var(--font-sans);
        font-weight: 700;
        font-size: var(--t-display);
        color: var(--fg-1);
        letter-spacing: var(--tr-display);
        line-height: var(--lh-display);
        max-width: 18ch;
        margin-bottom: var(--sp-6);
      "
    >
      Professional tools for network engineers
    </h1>

    <p
      class="fade-in"
      style="
        font-size: var(--t-body-l);
        color: var(--fg-2);
        max-width: 52ch;
        line-height: var(--lh-body);
        margin-bottom: var(--sp-8);
      "
    >
      Subnet calculators, VLSM planners, Cisco script generators, and topology
      tools. Free, no account required, runs entirely in your browser.
    </p>

    <div class="fade-in" style="display: flex; flex-wrap: wrap; gap: var(--sp-3); margin-bottom: var(--sp-8);">
      <a href="/subnetting/" class="btn-primary">Subnet Calculator →</a>
      <a href="#tools" class="btn-secondary">View all tools</a>
    </div>

    <p
      class="fade-in"
      style="font-size: 13px; color: var(--fg-3); letter-spacing: 0.01em;"
    >
      127 unit tests · Open source · Zero data collection
    </p>

  </section>

  <!-- Brand rule below hero -->
  <div style="max-width: var(--maxw-content); margin: 0 auto; padding: 0 var(--gutter);">
    <hr class="rule-brand" />
  </div>

  <!-- Ad slot -->
  <div style="display: flex; justify-content: center; padding: var(--sp-8) var(--gutter);">
    <AdSlot slot="leaderboard" />
  </div>

  <!-- Tools section -->
  <section
    id="tools"
    style="max-width: var(--maxw-content); margin: 0 auto; padding: 0 var(--gutter) var(--sp-20);"
    aria-labelledby="tools-heading"
  >

    <div style="display: flex; align-items: center; gap: var(--sp-4); padding-bottom: var(--sp-4);">
      <span class="eyebrow" id="tools-heading">Tools</span>
      <hr class="rule" style="flex: 1;" />
    </div>

    <ul role="list" style="list-style: none; padding: 0; margin: 0;">
      {tools.map(tool => (
        <li>
          <a
            href={tool.href}
            class="tool-row fade-in"
            aria-label={`Open ${tool.name}`}
          >
            <span style="
              font-family: var(--font-sans);
              font-weight: 600;
              font-size: var(--t-body-s);
              color: var(--fg-1);
              letter-spacing: -0.01em;
              white-space: nowrap;
            ">{tool.name}</span>

            <span style="
              font-size: var(--t-body-s);
              color: var(--fg-2);
              line-height: var(--lh-snug);
            ">{tool.description}</span>

            <span style="display: flex; align-items: center; gap: var(--sp-3); flex-shrink: 0;">
              <span class={`badge ${tool.badgeClass}`}>{tool.badge}</span>
              <span class="tool-row-arrow" style="color: var(--fg-accent); font-size: 1rem;">→</span>
            </span>
          </a>
        </li>
      ))}
    </ul>

  </section>

  <!-- Also available -->
  <section
    style="
      max-width: var(--maxw-content);
      margin: 0 auto;
      padding: 0 var(--gutter) var(--sp-24);
      border-top: 1px solid var(--border-1);
      padding-top: var(--sp-10);
    "
    aria-labelledby="also-heading"
  >

    <div style="display: flex; align-items: center; gap: var(--sp-4); margin-bottom: var(--sp-6);">
      <span class="eyebrow eyebrow-muted" id="also-heading">Also available</span>
      <hr class="rule" style="flex: 1;" />
    </div>

    <div style="display: flex; flex-direction: column; gap: var(--sp-3);">
      <a
        href="/articles/"
        class="fade-in"
        style="
          display: inline-flex;
          align-items: center;
          gap: var(--sp-2);
          font-size: var(--t-body-s);
          font-weight: 500;
          color: var(--fg-2);
          text-decoration: none;
          transition: color var(--dur-quick) var(--ease-out);
        "
        onmouseover="this.style.color='var(--fg-1)'"
        onmouseout="this.style.color='var(--fg-2)'"
      >
        Networking guides and reference articles
        <span style="transition: transform var(--dur-quick) var(--ease-out); display: inline-block;"
              onmouseover="this.style.transform='translateX(3px)'"
              onmouseout="this.style.transform='translateX(0)'">→</span>
      </a>

      <a
        href="/about/"
        class="fade-in"
        style="
          display: inline-flex;
          align-items: center;
          gap: var(--sp-2);
          font-size: var(--t-body-s);
          font-weight: 500;
          color: var(--fg-2);
          text-decoration: none;
          transition: color var(--dur-quick) var(--ease-out);
        "
        onmouseover="this.style.color='var(--fg-1)'"
        onmouseout="this.style.color='var(--fg-2)'"
      >
        About this project
        <span style="transition: transform var(--dur-quick) var(--ease-out); display: inline-block;"
              onmouseover="this.style.transform='translateX(3px)'"
              onmouseout="this.style.transform='translateX(0)'">→</span>
      </a>
    </div>

  </section>

</BaseLayout>

<style>
  @media (max-width: 640px) {
    .tool-row {
      grid-template-columns: 1fr !important;
      gap: 6px !important;
      padding: var(--sp-4) 0 !important;
    }
  }
</style>
