---
import BaseLayout from '../components/layout/BaseLayout.astro';
import AdSlot from '../components/ads/AdSlot.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "NetTools",
  "description": "Professional network engineering tools: subnet calculators, VLSM planners, Cisco script generators",
  "url": Astro.url.origin,
  "potentialAction": {
    "@type": "SearchAction",
    "target": `${Astro.url.origin}/subnetting/?q={search_term_string}`,
    "query-input": "required name=search_term_string"
  }
};

const tools = [
  {
    href: '/subnetting/',
    title: 'Subnet Calculator',
    description: 'IPv4/IPv6 CIDR calculator with VLSM planning, wildcard masks, and broadcast address computation.',
    badge: 'Free',
  },
  {
    href: '/cisco-scripts/',
    title: 'Cisco IOS Script Generator',
    description: 'Generate interface configs, OSPF/EIGRP setups, ACLs, and VLANs ready to paste into the console.',
    badge: 'Free',
  },
  {
    href: '/topology/',
    title: 'Topology Simulator',
    description: 'Drag-and-drop network topology builder with automatic IP assignment and adjacency tables.',
    badge: 'Beta',
  },
];
---

<BaseLayout
  title="NetTools — Network Engineering Toolkit"
  description="Free professional tools for network engineers: subnet calculators, VLSM planners, Cisco IOS script generators, and topology simulators."
  jsonLd={jsonLd}
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-4 pt-16 pb-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-[#1a1b1e] mb-4 leading-tight">
      Network engineering tools,<br/>
      <span class="text-brand-600">ready in seconds</span>
    </h1>
    <p class="text-lg text-[#495057] max-w-2xl mx-auto mb-8">
      Professional-grade subnet calculators, Cisco IOS script generators, and topology simulators.
      No login required.
    </p>
  </section>

  <!-- AdSlot leaderboard — antes del contenido principal -->
  <div class="flex justify-center pb-8">
    <AdSlot slot="leaderboard" />
  </div>

  <!-- Tool grid -->
  <section class="max-w-6xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {tools.map(tool => (
        <a href={tool.href} class="tool-card group block">
          <div class="flex items-center justify-between mb-3">
            <span class="section-label">Tool</span>
            <span class="text-xs font-medium bg-brand-50 text-brand-700 px-2 py-0.5 rounded-full">
              {tool.badge}
            </span>
          </div>
          <h2 class="text-lg font-semibold text-[#1a1b1e] mb-2 group-hover:text-brand-600 transition-colors">
            {tool.title}
          </h2>
          <p class="text-sm text-[#495057] leading-relaxed">{tool.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
