---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';

const articles = await getCollection('articles');
const sorted = articles.sort((a, b) =>
  b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---

<BaseLayout
  title="Networking Articles — Guides and References"
  description="Free networking guides, subnet cheat sheets, Cisco IOS configuration examples, and VLSM practice problems for network engineers."
>

  <!-- Header — editorial style -->
  <header class="max-w-3xl mx-auto px-4 pt-12 pb-10">
    <p class="section-label" style="margin-bottom: 0.875rem;">Knowledge base</p>
    <h1
      class="font-serif-display"
      style="font-size: clamp(2rem, 4vw, 3rem); color: var(--text-1); margin-bottom: 0.875rem;"
    >
      Networking articles
    </h1>
    <p style="font-size: 1rem; color: var(--text-2); line-height: 1.65; max-width: 52ch;">
      Guides, subnet references, and configuration examples for network engineers.
    </p>
  </header>

  <!-- Article list — editorial layout, not a card grid -->
  <section
    class="max-w-3xl mx-auto px-4 pb-20"
    style="border-top: 1px solid var(--border-subtle);"
  >
    {sorted.map((article, i) => {
      const date = article.data.pubDate.toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
      return (
        <a
          href={`/articles/${article.id}/`}
          style="
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 1.5rem;
            padding: 1.75rem 0;
            border-bottom: 1px solid var(--border-subtle);
            text-decoration: none;
            align-items: start;
            transition: none;
          "
          class="article-row"
        >
          <!-- Left: date + category -->
          <div>
            <p style="font-size: 0.75rem; color: var(--text-3); font-variant-numeric: tabular-nums; margin-bottom: 0.375rem;">
              {date}
            </p>
            <span
              style="
                display: inline-block;
                font-size: 0.625rem;
                font-weight: 600;
                letter-spacing: 0.08em;
                text-transform: uppercase;
                color: var(--accent-text);
                background-color: var(--accent-subtle);
                padding: 0.2rem 0.5rem;
                border-radius: 4px;
              "
            >
              {article.data.category}
            </span>
          </div>

          <!-- Right: title + description -->
          <div>
            <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
              <h2
                style="
                  font-size: 1.0625rem;
                  font-weight: 600;
                  color: var(--text-1);
                  letter-spacing: -0.02em;
                  line-height: 1.35;
                "
                class="article-title"
              >
                {article.data.title}
              </h2>
              {article.data.featured && (
                <span
                  style="
                    font-size: 0.625rem;
                    font-weight: 600;
                    letter-spacing: 0.06em;
                    text-transform: uppercase;
                    color: var(--warning);
                    background-color: var(--warning-subtle);
                    padding: 0.2rem 0.5rem;
                    border-radius: 4px;
                    white-space: nowrap;
                  "
                >
                  Featured
                </span>
              )}
            </div>
            <p style="font-size: 0.875rem; color: var(--text-2); line-height: 1.6;">
              {article.data.description}
            </p>
            {article.data.readingTime && (
              <p style="font-size: 0.75rem; color: var(--text-3); margin-top: 0.5rem;">
                {article.data.readingTime} min read
              </p>
            )}
          </div>
        </a>
      );
    })}
  </section>

</BaseLayout>

<style>
  .article-row:hover .article-title {
    color: var(--accent-text);
  }

  @media (max-width: 480px) {
    .article-row {
      grid-template-columns: 1fr !important;
      gap: 0.5rem !important;
    }
  }
</style>
