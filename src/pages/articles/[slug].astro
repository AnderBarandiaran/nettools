---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import AdSlot from '../../components/ads/AdSlot.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.description,
  "datePublished": article.data.pubDate.toISOString(),
  "dateModified": (article.data.updatedDate ?? article.data.pubDate).toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "NetTools",
    "url": Astro.url.origin,
  },
};
---

<BaseLayout
  title={article.data.title}
  description={article.data.description}
  ogType="article"
  jsonLd={jsonLd}
>
  <nav class="max-w-3xl mx-auto px-4 pt-6 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-2 text-sm text-[#868e96]">
      <li><a href="/" class="hover:text-brand-600">Home</a></li>
      <li aria-hidden="true">/</li>
      <li><a href="/articles/" class="hover:text-brand-600">Articles</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-[#1a1b1e] font-medium truncate max-w-[200px]">{article.data.title}</li>
    </ol>
  </nav>

  <div class="flex justify-center py-6">
    <AdSlot slot="leaderboard" />
  </div>

  <article class="max-w-3xl mx-auto px-4 pb-8">
    <header class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <span class="section-label">{article.data.category}</span>
        <span class="text-xs text-[#868e96]">
          {article.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-[#1a1b1e] leading-tight">
        {article.data.title}
      </h1>
    </header>

    <div class="flex justify-center mb-8">
      <AdSlot slot="rectangle" />
    </div>

    <div class="prose prose-slate max-w-none">
      <Content />
    </div>

    <div class="flex justify-center mt-8">
      <AdSlot slot="rectangle" />
    </div>
  </article>
</BaseLayout>
